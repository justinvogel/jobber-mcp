.env.local
.env.*.local
.jobber-tokens.json
.jobber-tokens.json.backup-*

# ── Logs ───────────────────────────────────────────────────────────────────
*.log
npm-debug.log*

# ── OS / editor ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

