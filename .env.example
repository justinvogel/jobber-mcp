# Jobber OAuth 2.0 credentials — obtain from https://developer.getjobber.com/
JOBBER_CLIENT_ID=your_client_id_here
JOBBER_CLIENT_SECRET=your_client_secret_here

# Must match the Redirect URI registered in your Jobber developer app.
# Default: http://localhost:8976/callback
JOBBER_REDIRECT_URI=http://localhost:8976/callback

# Jobber GraphQL API version — required header (X-JOBBER-GRAPHQL-VERSION).
# See https://developer.getjobber.com/docs/changelog
JOBBER_API_VERSION=2025-01-20

# Where to persist OAuth tokens on disk. Defaults to ./.jobber-tokens.json
# JOBBER_TOKEN_FILE=.jobber-tokens.json

# Optional: OAuth scopes to request (space-separated). If omitted, Jobber uses
# the scopes configured on your developer app.
# JOBBER_SCOPES=read_clients write_clients read_jobs write_jobs read_quotes write_quotes read_invoices write_invoices read_requests write_requests read_visits write_visits read_expenses write_expenses read_users read_time_sheets write_time_sheets
